# Copy this file to .env and adjust as needed. All values have safe
# built-in defaults (see app/config.py) -- .env is optional for local runs.

# SQLite database file location.
# DATABASE_URL=sqlite:///./voice_demo.db

# Where audio samples / generated clips are stored on disk.
# STORAGE_DIR=./storage

# --- Data retention (safety requirements #19-#21) ---------------------------
# Default session TTL in seconds. Default: 24 hours.
DEFAULT_TTL_SECONDS=86400
MIN_TTL_SECONDS=300
MAX_TTL_SECONDS=604800

# How often the background purge sweep runs, in seconds.
CLEANUP_INTERVAL_SECONDS=60

# Max allowed gap (seconds) between the consent-phrase segment and the
# reference-sample segment of one continuous capture before it's rejected
# as no longer "uninterrupted" (safety requirement #14).
CAPTURE_SESSION_MAX_GAP_SECONDS=120

# --- Provider ----------------------------------------------------------------
# Testing-only escape hatch to force the non-cloning fallback provider.
# Must NEVER be "true" in a real deployment -- LocalCloneProvider is always
# the intended default.
FORCE_FALLBACK_PROVIDER=false

# --- Networking ----------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# Max accepted size, in bytes, for a single live-recorded audio upload.
MAX_AUDIO_UPLOAD_BYTES=20971520
